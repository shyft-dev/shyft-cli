{
  "name": "@shyft-dev/cli",
  "version": "0.4.5",
  "description": "CLI for the Shyft platform",
  "type": "module",
  "bin": {
    "shyft": "bin/shyft.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && chmod +x bin/shyft.js",
    "lint": "eslint src/**/*.ts --fix",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "release": "./scripts/release.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shyft-dev/shyft-cli.git"
  },
  "homepage": "https://github.com/shyft-dev/shyft-cli#readme",
  "bugs": {
    "url": "https://github.com/shyft-dev/shyft-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.0",
    "form-data": "^4.0.5",
    "open": "^10.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "license": "MIT"
}
